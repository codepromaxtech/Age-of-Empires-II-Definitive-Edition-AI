; ============================================================
; AL-AMIN2.0 - Age of Empires II: Definitive Edition AI
; Strategy: Defensive Fortress with Retaliatory Counter-Attack
; ============================================================

; --- CONSTANTS ---
(defconst gl-dark-age-vils 22)
(defconst gl-feudal-age-vils 40)
(defconst gl-castle-age-vils 100)
(defconst gl-imperial-age-vils 130)

; ============================================================
; PHASE 1: INITIALIZATION
; ============================================================

(defrule
    (true)
=>
    ; --- Building System ---
    (set-strategic-number sn-enable-new-building-system 1)
    (set-strategic-number sn-percent-building-cancellation 20)
    (set-strategic-number sn-cap-civilian-builders 4)

    ; --- Training & Research Queuing (queue units/techs faster) ---
    (set-strategic-number sn-enable-training-queue 2)
    (set-strategic-number sn-enable-research-queue 1)

    ; --- Exploration ---
    (set-strategic-number sn-total-number-explorers 1)
    (set-strategic-number sn-number-explore-groups 1)
    (set-strategic-number sn-initial-exploration-required 0)
    (set-strategic-number sn-percent-exploration-required 50)
    (set-strategic-number sn-home-exploration-time 300)

    ; --- Economy (Dark Age: heavy food) ---
    (set-strategic-number sn-food-gatherer-percentage 60)
    (set-strategic-number sn-wood-gatherer-percentage 30)
    (set-strategic-number sn-gold-gatherer-percentage 0)
    (set-strategic-number sn-stone-gatherer-percentage 10)
    (set-strategic-number sn-percent-civilian-gatherers 100)

    ; --- Boar Hunting & Foraging ---
    (set-strategic-number sn-enable-boar-hunting 2)
    (set-strategic-number sn-minimum-boar-hunt-group-size 3)
    (set-strategic-number sn-minimum-number-hunters 4)
    (set-strategic-number sn-livestock-to-town-center 1)
    (disable-self)
)

(defrule
    (true)
=>
    ; --- Town Layout & Safe Zone ---
    (set-strategic-number sn-maximum-town-size 20)
    (set-strategic-number sn-minimum-town-size 12)
    (set-strategic-number sn-safe-town-size 30)
    (set-strategic-number sn-camp-max-distance 20)
    (set-strategic-number sn-mill-max-distance 20)
    (set-strategic-number sn-lumber-camp-max-distance 25)
    (set-strategic-number sn-mining-camp-max-distance 25)

    ; --- Dropsite Optimization ---
    (set-strategic-number sn-food-dropsite-distance 4)
    (set-strategic-number sn-wood-dropsite-distance 4)
    (set-strategic-number sn-gold-dropsite-distance 4)
    (set-strategic-number sn-stone-dropsite-distance 4)
    (set-strategic-number sn-dropsite-separation-distance 8)

    ; --- Building Repair ---
    (set-strategic-number sn-object-repair-level 1)

    ; --- Defensive Posture (NO unprovoked attacks) ---
    (set-strategic-number sn-percent-enemy-sighted-response 100)
    (set-strategic-number sn-enemy-sighted-response-distance 10)
    (set-strategic-number sn-number-attack-groups 0)
    (set-strategic-number sn-minimum-attack-group-size 20)
    (set-strategic-number sn-maximum-attack-group-size 40)
    (set-strategic-number sn-number-defend-groups 3)
    (set-strategic-number sn-minimum-defend-group-size 5)
    (set-strategic-number sn-maximum-defend-group-size 20)
    (set-strategic-number sn-defense-distance 8)
    (set-strategic-number sn-sentry-distance 10)
    (set-strategic-number sn-sentry-distance-variation 2)
    (disable-self)
)

(defrule
    (true)
=>
    ; --- Attack Intelligence & Patrol ---
    (set-strategic-number sn-attack-intelligence 1)
    (set-strategic-number sn-enable-patrol-attack 1)
    (set-strategic-number sn-initial-attack-delay 0)
    (set-strategic-number sn-initial-attack-delay-type 0)
    (set-strategic-number sn-ignore-attack-group-under-attack 1)

    ; --- Garrison Control ---
    (set-strategic-number sn-maximum-garrison-fill 15)
    (set-strategic-number sn-number-garrison-units 5)

    ; --- Idle Soldier Management ---
    (set-strategic-number sn-gather-idle-soldiers-at-center 1)
    (set-strategic-number sn-gather-defense-units 1)
    (set-strategic-number sn-task-ungrouped-soldiers 1)
    (set-strategic-number sn-number-civilian-militia 6)

    ; --- Difficulty: consistent behavior at all levels ---
    (set-strategic-number sn-do-not-scale-for-difficulty-level 1)
    (set-strategic-number sn-easiest-reaction-percentage 100)
    (set-strategic-number sn-easier-reaction-percentage 100)

    ; --- Cooperative Play (Team games) ---
    (set-strategic-number sn-coop-share-information 1)
    (set-strategic-number sn-coop-share-attacking 1)

    ; --- Advanced Building Targeting (defensive focus) ---
    (set-strategic-number sn-building-targeting-mode 1)
    (set-strategic-number sn-wall-targeting-mode 1)

    (disable-self)
)

; ============================================================
; PHASE 2: VILLAGER PRODUCTION (Zero Idle Time)
; ============================================================

(defrule
    (current-age == dark-age)
    (unit-type-count-total villager < gl-dark-age-vils)
    (can-train villager)
=>
    (train villager)
)

(defrule
    (current-age == feudal-age)
    (unit-type-count-total villager < gl-feudal-age-vils)
    (can-train villager)
=>
    (train villager)
)

(defrule
    (current-age == castle-age)
    (unit-type-count-total villager < gl-castle-age-vils)
    (can-train villager)
=>
    (train villager)
)

(defrule
    (current-age >= imperial-age)
    (unit-type-count-total villager < gl-imperial-age-vils)
    (can-train villager)
=>
    (train villager)
)

; ============================================================
; PHASE 3: HOUSE CONSTRUCTION
; ============================================================

(defrule
    (housing-headroom < 5)
    (population-headroom > 0)
    (can-build house)
=>
    (build house)
)

; ============================================================
; PHASE 4: ECONOMIC BUILDINGS
; ============================================================

; --- Dark Age Essentials ---
(defrule
    (building-type-count-total lumber-camp < 1)
    (resource-found wood)
    (can-build lumber-camp)
=>
    (build lumber-camp)
)

(defrule
    (building-type-count-total mill < 1)
    (resource-found food)
    (can-build mill)
=>
    (build mill)
)

; Barracks in Dark Age is REQUIRED as a prerequisite for Feudal Age
(defrule
    (current-age == dark-age)
    (building-type-count-total barracks < 1)
    (can-build barracks)
=>
    (build barracks)
)

; --- Additional Economic Buildings (scaling) ---
(defrule
    (current-age >= feudal-age)
    (building-type-count-total lumber-camp < 2)
    (resource-found wood)
    (can-build lumber-camp)
=>
    (build lumber-camp)
)

(defrule
    (current-age >= castle-age)
    (building-type-count-total mining-camp < 2)
    (resource-found gold)
    (can-build mining-camp)
=>
    (build mining-camp)
)

(defrule
    (current-age >= castle-age)
    (building-type-count-total lumber-camp < 3)
    (resource-found wood)
    (can-build lumber-camp)
=>
    (build lumber-camp)
)

; ============================================================
; PHASE 5: FARMS (auto-seed)
; ============================================================

(defrule
    (current-age == dark-age)
    (building-type-count-total mill > 0)
    (building-type-count-total farm < 6)
    (can-build farm)
=>
    (build farm)
)

(defrule
    (current-age == feudal-age)
    (building-type-count-total farm < 14)
    (can-build farm)
=>
    (build farm)
)

(defrule
    (current-age == castle-age)
    (building-type-count-total farm < 28)
    (can-build farm)
=>
    (build farm)
)

(defrule
    (current-age >= imperial-age)
    (building-type-count-total farm < 40)
    (can-build farm)
=>
    (build farm)
)

; Reseed dead farms
(defrule
    (idle-farm-count > 0)
    (can-build farm)
=>
    (build farm)
)

; ============================================================
; PHASE 6: AGE TRANSITIONS
; ============================================================

(defrule
    (can-research feudal-age)
=>
    (research feudal-age)
    (chat-to-all "AL-AMIN2.0: Advancing to Feudal Age...")
)

(defrule
    (can-research castle-age)
=>
    (research castle-age)
    (chat-to-all "AL-AMIN2.0: Advancing to Castle Age...")
)

(defrule
    (can-research imperial-age)
=>
    (research imperial-age)
    (chat-to-all "AL-AMIN2.0: Advancing to Imperial Age...")
)

; ============================================================
; PHASE 7: RESOURCE ALLOCATION PER AGE
; ============================================================

(defrule
    (current-age == feudal-age)
=>
    (set-strategic-number sn-food-gatherer-percentage 45)
    (set-strategic-number sn-wood-gatherer-percentage 35)
    (set-strategic-number sn-gold-gatherer-percentage 10)
    (set-strategic-number sn-stone-gatherer-percentage 10)
    (set-strategic-number sn-maximum-town-size 30)
    (disable-self)
)

(defrule
    (current-age == castle-age)
=>
    (set-strategic-number sn-food-gatherer-percentage 35)
    (set-strategic-number sn-wood-gatherer-percentage 25)
    (set-strategic-number sn-gold-gatherer-percentage 25)
    (set-strategic-number sn-stone-gatherer-percentage 15)
    (set-strategic-number sn-maximum-town-size 50)
    (disable-self)
)

(defrule
    (current-age >= imperial-age)
=>
    (set-strategic-number sn-food-gatherer-percentage 35)
    (set-strategic-number sn-wood-gatherer-percentage 20)
    (set-strategic-number sn-gold-gatherer-percentage 30)
    (set-strategic-number sn-stone-gatherer-percentage 15)
    (set-strategic-number sn-maximum-town-size 80)
    (disable-self)
)

; ============================================================
; PHASE 8: MILITARY BUILDINGS
; ============================================================

; --- Feudal Age ---
(defrule
    (current-age >= feudal-age)
    (building-type-count-total archery-range < 1)
    (can-build archery-range)
=>
    (build archery-range)
)

(defrule
    (current-age >= feudal-age)
    (building-type-count-total blacksmith < 1)
    (can-build blacksmith)
=>
    (build blacksmith)
)

(defrule
    (current-age >= feudal-age)
    (building-type-count-total barracks < 2)
    (can-build barracks)
=>
    (build barracks)
)

; --- Castle Age ---
(defrule
    (current-age >= castle-age)
    (building-type-count-total archery-range < 3)
    (can-build archery-range)
=>
    (build archery-range)
)

(defrule
    (current-age >= castle-age)
    (building-type-count-total stable < 1)
    (can-build stable)
=>
    (build stable)
)

(defrule
    (current-age >= castle-age)
    (building-type-count-total siege-workshop < 1)
    (can-build siege-workshop)
=>
    (build siege-workshop)
)

(defrule
    (current-age >= castle-age)
    (building-type-count-total university < 1)
    (can-build university)
=>
    (build university)
)

; --- Additional Town Centers (Economic Boom) ---
(defrule
    (current-age >= castle-age)
    (building-type-count-total town-center < 2)
    (can-build town-center)
=>
    (build town-center)
)

(defrule
    (current-age >= castle-age)
    (building-type-count-total town-center < 3)
    (can-build town-center)
=>
    (build town-center)
)

(defrule
    (current-age >= imperial-age)
    (building-type-count-total town-center < 4)
    (can-build town-center)
=>
    (build town-center)
)

; --- Imperial Age ---
(defrule
    (current-age >= imperial-age)
    (building-type-count-total barracks < 4)
    (can-build barracks)
=>
    (build barracks)
)

(defrule
    (current-age >= imperial-age)
    (building-type-count-total archery-range < 5)
    (can-build archery-range)
=>
    (build archery-range)
)

(defrule
    (current-age >= imperial-age)
    (building-type-count-total stable < 2)
    (can-build stable)
=>
    (build stable)
)

(defrule
    (current-age >= imperial-age)
    (building-type-count-total siege-workshop < 2)
    (can-build siege-workshop)
=>
    (build siege-workshop)
)

; ============================================================
; PHASE 9: BEAUTIFUL FORTRESS - WALLS, TOWERS, CASTLES
; ============================================================

; --- Walls (enable palisade in Feudal, stone in Castle) ---
(defrule
    (current-age == feudal-age)
=>
    (enable-wall-placement 1)
    (enable-wall-placement 2)
    (chat-to-all "AL-AMIN2.0: Fortifying the perimeter with palisades...")
    (disable-self)
)

; Build palisade walls at perimeter 1 (inner)
(defrule
    (current-age >= feudal-age)
    (can-build-wall 1 palisade-wall)
=>
    (build-wall 1 palisade-wall)
)

; Build gate at perimeter 1
(defrule
    (current-age >= feudal-age)
    (can-build-gate 1)
=>
    (build-gate 1)
)

(defrule
    (current-age >= castle-age)
=>
    (enable-wall-placement 2)
    (set-strategic-number sn-gate-type-for-wall 1)
    (chat-to-all "AL-AMIN2.0: Upgrading to stone walls...")
    (disable-self)
)

; Build stone walls at perimeter 2 (outer)
(defrule
    (current-age >= castle-age)
    (can-build-wall 2 stone-wall)
=>
    (build-wall 2 stone-wall)
)

; Build gate at perimeter 2
(defrule
    (current-age >= castle-age)
    (can-build-gate 2)
=>
    (build-gate 2)
)

; --- Towers ---
(defrule
    (current-age >= feudal-age)
    (building-type-count-total watch-tower < 4)
    (can-build watch-tower)
=>
    (build watch-tower)
)

(defrule
    (current-age >= castle-age)
    (building-type-count-total watch-tower < 8)
    (can-build watch-tower)
=>
    (build watch-tower)
)

(defrule
    (current-age >= imperial-age)
    (building-type-count-total watch-tower < 12)
    (can-build watch-tower)
=>
    (build watch-tower)
)

; --- Castles ---
(defrule
    (current-age >= castle-age)
    (building-type-count-total castle < 2)
    (can-build castle)
=>
    (build castle)
)

(defrule
    (current-age >= imperial-age)
    (building-type-count-total castle < 4)
    (can-build castle)
=>
    (build castle)
)

; --- Additional Town Centers (boom economy) ---
(defrule
    (current-age >= castle-age)
    (building-type-count-total town-center < 3)
    (can-build town-center)
=>
    (build town-center)
)

