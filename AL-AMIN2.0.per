; --- Siege Workshop Upgrades ---
(defrule
    (can-research ri-capped-ram)
=>
    (research ri-capped-ram)
)

(defrule
    (can-research ri-onager)
=>
    (research ri-onager)
)

(defrule
    (can-research ri-heavy-scorpion)
=>
    (research ri-heavy-scorpion)
)

; --- Town Center (Visibility) ---
(defrule
    (can-research ri-town-watch)
=>
    (research ri-town-watch)
)

(defrule
    (can-research ri-town-patrol)
=>
    (research ri-town-patrol)
)

; --- Castle Upgrades ---
(defrule
    (can-research ri-conscription)
=>
    (research ri-conscription)
)

(defrule
    (can-research ri-hoardings)
=>
    (research ri-hoardings)
)

(defrule
    (can-research ri-sappers)
=>
    (research ri-sappers)
)

; ============================================================
; PHASE 12: MILITARY PRODUCTION (Standby Garrison Force)
; ============================================================

; --- Scout Cavalry: Dark Age scouting ---
(defrule
    (current-age == dark-age)
    (unit-type-count-total scout-cavalry-line < 1)
    (can-train scout-cavalry-line)
=>
    (train scout-cavalry-line)
)

; --- Archers: primary defensive garrison unit ---
(defrule
    (current-age >= feudal-age)
    (unit-type-count-total archer-line < 10)
    (can-train archer-line)
=>
    (train archer-line)
)

(defrule
    (current-age >= castle-age)
    (unit-type-count-total archer-line < 25)
    (can-train archer-line)
=>
    (train archer-line)
)

(defrule
    (current-age >= imperial-age)
    (unit-type-count-total archer-line < 40)
    (can-train archer-line)
=>
    (train archer-line)
)

; --- Skirmishers: counter enemy archers ---
(defrule
    (current-age >= feudal-age)
    (unit-type-count-total skirmisher-line < 6)
    (can-train skirmisher-line)
=>
    (train skirmisher-line)
)

(defrule
    (current-age >= castle-age)
    (unit-type-count-total skirmisher-line < 12)
    (can-train skirmisher-line)
=>
    (train skirmisher-line)
)

; --- Spearmen / Pikemen: anti-cavalry defense ---
(defrule
    (current-age >= feudal-age)
    (unit-type-count-total spearman-line < 6)
    (can-train spearman-line)
=>
    (train spearman-line)
)

(defrule
    (current-age >= castle-age)
    (unit-type-count-total spearman-line < 15)
    (can-train spearman-line)
=>
    (train spearman-line)
)

; --- Cavalry Archers: mobile ranged DPS behind walls ---
(defrule
    (current-age >= castle-age)
    (unit-type-count-total cavalry-archer-line < 10)
    (can-train cavalry-archer-line)
=>
    (train cavalry-archer-line)
)

(defrule
    (current-age >= imperial-age)
    (unit-type-count-total cavalry-archer-line < 20)
    (can-train cavalry-archer-line)
=>
    (train cavalry-archer-line)
)

; --- Knights: mobile counter-attack force ---
(defrule
    (current-age >= castle-age)
    (unit-type-count-total knight-line < 10)
    (can-train knight-line)
=>
    (train knight-line)
)

(defrule
    (current-age >= imperial-age)
    (unit-type-count-total knight-line < 20)
    (can-train knight-line)
=>
    (train knight-line)
)

; --- Mangonels / Onagers: area denial behind walls ---
(defrule
    (current-age >= castle-age)
    (unit-type-count-total mangonel-line < 3)
    (can-train mangonel-line)
=>
    (train mangonel-line)
)

(defrule
    (current-age >= imperial-age)
    (unit-type-count-total mangonel-line < 6)
    (can-train mangonel-line)
=>
    (train mangonel-line)
)

; --- Scorpions: massed anti-infantry behind walls ---
(defrule
    (current-age >= castle-age)
    (unit-type-count-total scorpion-line < 4)
    (can-train scorpion-line)
=>
    (train scorpion-line)
)

(defrule
    (current-age >= imperial-age)
    (unit-type-count-total scorpion-line < 8)
    (can-train scorpion-line)
=>
    (train scorpion-line)
)

; --- Battering Rams: siege for retaliatory strikes ---
(defrule
    (current-age >= castle-age)
