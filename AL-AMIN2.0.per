    (can-train battering-ram-line)
=>
    (train battering-ram-line)
)

; --- Trebuchets: smash attackers' siege and buildings ---
(defrule
    (current-age >= imperial-age)
    (unit-type-count-total trebuchet < 5)
    (can-train trebuchet)
=>
    (train trebuchet)
)

; --- Bombard Cannons: powerful ranged siege/defense ---
(defrule
    (current-age >= imperial-age)
    (unit-type-count-total bombard-cannon < 4)
    (can-train bombard-cannon)
=>
    (train bombard-cannon)
)

; --- Champion: beefy front-line defense ---
(defrule
    (current-age >= imperial-age)
    (unit-type-count-total militiaman-line < 20)
    (can-train militiaman-line)
=>
    (train militiaman-line)
)

; --- Hussars: rapid counter-raiding force ---
(defrule
