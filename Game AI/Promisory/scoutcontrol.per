(defrule
   (goal modern-scout-micro yes)
   (goal multi-group-reinforcing no)
   (unit-type-count-total scout-cavalry-line > 1)
   (strategic-number sn-five-turns == 3)
   ;(up-compare-goal scout-group-x > 1)
   ;(up-compare-goal scout-group-y > 1)
=>
   (up-full-reset-search)
   (up-find-local c: scout-cavalry-line c: 40)
   (up-set-target-point scout-group-x)
   ;(up-filter-distance c: -1 c: 80)
   (up-remove-objects search-local object-data-group-flag == 12)
   (up-target-point scout-group-x action-move -1 stance-no-attack)
)

(defrule
   (goal modern-scout-micro yes)
   (goal multi-group-reinforcing yes)
   (unit-type-count-total scout-cavalry-line > 1)
   (strategic-number sn-five-turns == 3)
   (up-compare-goal scout-group-x > 1)
   (up-compare-goal scout-group-y > 1)
=>
   (up-full-reset-search)
   (up-find-local c: scout-cavalry-line c: 60)
   (up-set-target-point scout-group-x)

   (up-remove-objects search-local object-data-group-flag != 13)
   (up-target-point scout-group-x action-move -1 stance-no-attack)
)

(defrule
   (goal modern-scout-micro yes)
   (goal multi-group-reinforcing yes)
   (unit-type-count-total scout-cavalry-line > 1)
   (strategic-number sn-five-turns == 3)
   (up-compare-goal scout-group-x > 1)
   (up-compare-goal scout-group-y > 1)
=>
   (up-full-reset-search)
   (up-filter-distance c: -1 c: 80)
   (up-find-local c: scout-cavalry-line c: 60)
   (up-set-target-point pivot-point-x)
   (up-remove-objects search-local object-data-group-flag == 12)
   (up-remove-objects search-local object-data-group-flag == 13)
   (up-target-point pivot-point-x action-move -1 stance-no-attack)
)

(defrule
   (goal modern-scout-micro yes)
   (goal multi-group-reinforcing yes)
   (strategic-number sn-five-turns == 2)
=>
   (up-full-reset-search)
   (up-set-target-point pivot-point-x)
   (up-filter-distance c: -1 c: 8)
   (up-set-group search-local c: 13)
   (up-modify-group-flag 0 c: 13)
   (up-reset-group c: 13)
   (up-find-local c: scout-cavalry-line c: 60)
   (up-clean-search search-local -1 search-order-none);remove duplicates
   (up-create-group 0 0 c: 13)
   (up-modify-group-flag 1 c: 13)
)


(defrule
   (taunt-detected 1 209)
=>
   (fe-break-point 1 c:== 1 -1)
   (disable-self)
)
;Calculate waypoints

(defrule
   (true)
=>
   (set-goal scout-radius 20)
   (disable-self)
)

(defrule
   (true)
=>
   (up-modify-goal temporary-goal g:= scout-radius)
   (up-modify-goal temporary-goal c:* 2)
   (up-modify-goal temporary-goal c:* 3141)
   (up-modify-goal temporary-goal c:/ 1000);diameter = 2pi r   
   (up-modify-goal temporary-goal2 g:= temporary-goal)
   (up-modify-goal temporary-goal2 c:/ 5)
   (set-goal temporary-goal4 3)
)
(defrule
   (goal scout-waypoint 0)
=>
   (up-bound-point scout-waypoint-x enemy-x)
   (up-lerp-tiles scout-waypoint-x position-self-x g: scout-radius)
)

(defrule
   (goal scout-waypoint 1)
=>
   ;(fe-break-point 1 c:== 1 -1)
   (up-bound-point scout-waypoint-x enemy-x)
   (up-lerp-tiles scout-waypoint-x position-self-x g: scout-radius)
   ;(up-send-flare scout-waypoint-x)
   ;(up-cross-tiles scout-waypoint-x enemy-x g: temporary-goal2)
   ;(set-goal input-angleAU 65535) 
   (set-goal input-angleRad 6283)
   ;(up-modify-goal input-angleAU c:/ 5)
   ;(up-modify-goal input-angleAU c:- 32767)
   (up-modify-goal input-angleRad c:/ 5)
   (up-modify-goal input-angleRad c:* 1)
   (up-copy-point input-origin-x enemy-x)
   (up-copy-point input-point-x scout-waypoint-x)
   ;(xs-script-call "RotateByAngle")
   (xs-script-call "RotateByAngleNoConvert")
   (up-bound-point scout-waypoint-x input-point-x)
   ;(up-send-flare scout-waypoint-x)
)

(defrule
   (goal scout-waypoint 2)
=>
   ;(fe-break-point 1 c:== 1 -1)
   (up-bound-point scout-waypoint-x enemy-x)
   ;(up-send-flare scout-waypoint-x)
   (up-lerp-tiles scout-waypoint-x position-self-x g: scout-radius)
   ;(up-modify-goal temporary-goal2 c:* 2)
   ;(up-send-flare scout-waypoint-x)
   (set-goal input-angleRad 6283)
   (up-modify-goal input-angleRad c:/ 5)
   (up-modify-goal input-angleRad c:* 2)
   (up-copy-point input-origin-x enemy-x)
   (up-copy-point input-point-x scout-waypoint-x)
   (xs-script-call "RotateByAngleNoConvert")
   (up-bound-point scout-waypoint-x input-point-x)
   ;(up-cross-tiles scout-waypoint-x enemy-x g: temporary-goal2)
   ;(up-cross-tiles scout-waypoint-x enemy-x g: temporary-goal2)
   ;(up-send-flare scout-waypoint-x)
)

(defrule
   (goal scout-waypoint -1)
=>
   (up-bound-point scout-waypoint-x enemy-x)
   (up-lerp-tiles scout-waypoint-x position-self-x g: scout-radius)
   (set-goal input-angleRad 6283)
   (up-modify-goal input-angleRad c:/ 5)
   (up-modify-goal input-angleRad c:* 4)
   (up-copy-point input-origin-x enemy-x)
   (up-copy-point input-point-x scout-waypoint-x)
   (xs-script-call "RotateByAngleNoConvert")
   (up-bound-point scout-waypoint-x input-point-x)
   (up-bound-point scout-waypoint-x scout-waypoint-x)
)

(defrule
   (goal scout-waypoint -2)
=>
   (up-bound-point scout-waypoint-x enemy-x)
   (up-lerp-tiles scout-waypoint-x position-self-x g: scout-radius)
   (set-goal input-angleRad 6283)
   (up-modify-goal input-angleRad c:/ 5)
   (up-modify-goal input-angleRad c:* 3)
   (up-copy-point input-origin-x enemy-x)
   (up-copy-point input-point-x scout-waypoint-x)
