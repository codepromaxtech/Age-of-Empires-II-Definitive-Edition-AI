;Select waypoint

(defrule
   (up-point-distance scout-waypoint-x scout-group-x < 5)
=>
   (up-modify-goal scout-waypoint g:+ movement-direction)
)

(defrule
   (up-compare-goal scout-waypoint >= 3)
=>
   (set-goal scout-waypoint -2)
   (up-modify-goal scout-radius c:- 2)
   (up-modify-goal scout-radius c:max 13)
)

(defrule
   (up-compare-goal scout-waypoint <= -3)
=>
   (set-goal scout-waypoint 2)
   (up-modify-goal scout-radius c:- 2)
   (up-modify-goal scout-radius c:max 13)
)

(defrule
   (timer-triggered fifteensec)
   (up-compare-goal scout-radius > 45)
=>
   (up-modify-goal scout-radius c:- 4)
)
(defrule
   (up-compare-goal scout-radius > 15)
   (or(timer-triggered one-min)
   (and(strategic-number sn-twenty-turns == 3)
   (up-compare-goal scout-radius > 23)))
=>
   (up-modify-goal scout-radius c:- 1)
   (up-modify-goal scout-radius c:max 13)
   )

