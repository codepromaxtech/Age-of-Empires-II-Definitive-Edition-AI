
(defrule
   (or(strategic-number sn-turn-count < 30)
   (timer-triggered fifteensec))
=>
   (set-goal modern-scout-micro no)
)

(defrule
   (timer-triggered fifteensec)
   (game-time < 1800)
   (up-compare-sn turn-time-estimate < 400)
   (unit-type-count scout-cavalry-line > 2)
   (up-compare-const diff-fp == 1)
   (up-group-size c: ranged-group1 < 5)
   (unit-type-count knight-line < 1)
=>
   (set-goal modern-scout-micro yes)
)

(defrule
   (up-compare-goal scout-jump-id < 1)
=>
   (up-jump-rule 1)
)

(defrule
   (goal modern-scout-micro no)
=>
   (up-jump-direct g: scout-jump-id)
)

(defrule
   (current-age == feudal-age)
   (game-time > 5)
=>
   (xs-script-call "VerifyLoad")
   (disable-self)
)


(defrule
   (timer-triggered two-mins)
   (random-number < 95)
=>
   (up-find-player enemy find-closest temporary-goal)
   (up-modify-sn sn-target-player-number g:= temporary-goal)
)

(defrule
   (timer-triggered two-mins)
   (random-number >= 95)
=>
   (up-find-player enemy find-random temporary-goal)
   (up-modify-sn sn-target-player-number g:= temporary-goal)
)

(defrule 
   (game-time > 2)
=>
   (up-find-player enemy find-closest temporary-goal)
   (set-strategic-number sn-target-player-number 2)
   (set-strategic-number sn-focus-player-number 2)
   (up-find-remote c: town-center c: 1)
   (up-set-target-object search-remote c: 0)
   (up-get-point position-object enemy-x)
   (up-get-point position-self position-self-x)
   ;(up-send-flare enemy-x)
   (set-goal scout-waypoint 0)
   (set-goal scout-waypoint-x 0)
   (set-goal scout-waypoint-y 0)
   (set-goal movement-direction 1)
   (up-bound-point scout-group-x position-self-x)
   (set-goal previous-scout-group-x 0)
   (set-goal previous-scout-group-y 0)
   (set-goal scout-formation formation-line)
   (set-goal modern-scout-micro yes)
   (set-goal scout-action 0)
   (set-goal temporary-goal9 50)
   (set-strategic-number sn-initial-exploration-required 0)
   (disable-self)
)

(defrule
   (goal modern-scout-micro no)
=>
   (up-jump-rule 60)
)

(defrule
   (players-building-type-count target-player town-center < 1)
=>
   (up-get-point position-flank enemy-x)
)

(defrule
   (players-building-type-count target-player town-center > 0)
=>
   (up-full-reset-search)
   (up-find-remote c: town-center c: 1)
   (up-set-target-object search-remote c: 0)
   (up-get-point position-object enemy-x)
)

(defrule
   (true)
=>
   (set-goal temporary-goal3 0)
   (set-goal temporary-goal2 0)
   (set-goal temporary-goal 0)
   (set-goal scout-sup 0)
   (set-goal enemy-str 0)
   (set-goal scout-str 0)
)

(defrule
   (goal modern-scout-micro yes)
   (up-group-size c: 12 < 2)
   (unit-type-count scout-cavalry > 2)
   (up-timer-status 6 != timer-running)
=>
   (up-full-reset-search)
   (up-find-local c: scout-cavalry c: 40)
   (up-target-point position-self-x action-move -1 -1)
   (set-goal scout-action scout-retreat)
   (enable-timer 6 15)
)
;Create group

(defrule
   (goal modern-scout-micro yes)
   (unit-type-count scout-cavalry-line > 1)
   (strategic-number sn-five-turns == 2)
   ;(up-group-size c: 12 < 1)
=>
   (up-full-reset-search)
   (up-find-local c: scout-cavalry-line c: 40)
   (up-set-target-point scout-group-x)
   (up-clean-search search-local object-data-distance search-order-asc)
)

(defrule
   (goal modern-scout-micro yes)
   (unit-type-count scout-cavalry-line > 1)
   (strategic-number sn-five-turns == 2)
   ;(up-group-size c: 12 < 1)
   (up-set-target-object search-local c: 0)
=>
   (up-get-point position-object point-x)
   (up-set-target-point point-x)
   (up-full-reset-search)
   (up-filter-distance c: -1 c: 7)
   (up-find-local c: scout-cavalry c: 40)
   (up-modify-group-flag 0 c: 12)
   (up-reset-group c: 12)
   (up-create-group 0 0 c: 12)
   (up-modify-group-flag 1 c: 12)
)

(defrule
   (goal modern-scout-micro yes)
   (up-group-size c: 12 > 1)
=>
   (up-full-reset-search)
   (up-set-group search-local c: 12)
   (set-goal temporary-goal3 0)
   (set-goal point-x 0)
   (set-goal point-y 0)
   (set-goal scout-group-x 0)
   (set-goal scout-group-y 0)
)

(defrule
   (goal modern-scout-micro yes)
   (up-group-size c: 12 > 1)
   (up-set-target-object search-local c: 0)
   (up-compare-goal temporary-goal3 < 20)
=>
   (up-get-point position-object point-x)
   (up-modify-goal scout-group-x g:+ point-x)
   (up-modify-goal scout-group-y g:+ point-y)
   (up-remove-objects search-local -1 c:== 0)
   (up-modify-goal temporary-goal3 c:+ 1)
   (up-jump-rule -1)
)

(defrule
   (goal modern-scout-micro yes)
   (up-group-size c: 12 > 1)
=>
   (up-modify-goal scout-group-x g:/ temporary-goal3)
   (up-modify-goal scout-group-y g:/ temporary-goal3)
)

;Analyze path to group to make sure it is safe
;We break it down into four quartersteps and analyze whether there is a TC, a massive group of spears/archers, a castle
(defrule
   (goal modern-scout-micro yes)
   (up-group-size c: 12 > 3)
   (strategic-number sn-twenty-turns == 12)
=>
   (up-full-reset-search)
   (set-goal temporary-goal 20)
   (set-strategic-number sn-focus-player-number 1)
   (set-goal remote-total 0)
   (set-goal temporary-goal3 0)
)

(defrule
   (strategic-number sn-twenty-turns == 12)
   (goal modern-scout-micro yes)
   (up-group-size c: 12 > 3)
   (player-valid focus-player)
   (players-stance focus-player enemy)
   (up-compare-goal temporary-goal < 100)
   (strategic-number sn-focus-player-number <= max-players)
   (up-compare-goal remote-total < 1)
   (up-compare-goal temporary-goal3 < 1)
=>
   (up-full-reset-search)
   (up-bound-point point-x position-self-x)
   (up-lerp-percent point-x enemy-x g: temporary-goal)
   (up-filter-distance c: -1 c: 9);7
   (up-find-remote c: archer c: 25)
   (up-get-search-state local-total)
   (up-modify-goal remote-total c:- 10)
   (up-modify-goal remote-total c:max 0)
   (up-modify-goal temporary-goal3 g:max remote-total)
   (up-find-remote c: spearman-line c: 1)
   (up-find-remote c: town-center c: 1)
   (up-find-remote c: castle c: 1)
   (up-get-search-state local-total)
   ;(up-jump-rule -1)
)


(defrule
   (strategic-number sn-twenty-turns == 12)
   (goal modern-scout-micro yes)
   (up-group-size c: 12 > 3)
   (player-valid focus-player)
   ;(players-stance focus-player enemy)
   (up-compare-goal temporary-goal < 100)
   (strategic-number sn-focus-player-number <= max-players)
=>
   (up-modify-sn sn-focus-player-number c:+ 1)
   (up-jump-rule -2)
)
(defrule
   (strategic-number sn-twenty-turns == 12)
   (goal modern-scout-micro yes)
   (up-group-size c: 12 > 3)
   (player-valid focus-player)
   (players-stance focus-player enemy)
   (up-compare-goal temporary-goal < 100)
   (strategic-number sn-focus-player-number <= max-players)
   (up-compare-goal temporary-goal3 < 1)
   (up-compare-goal remote-total < 1)
=>
   (up-modify-goal temporary-goal c:+ 20)
   (up-jump-rule -3)
)

(defrule 
   (or(timer-triggered one-min)
   (or(up-group-size c: 12 < 4)
   (and(up-compare-goal temporary-goal3 < 1)
   (and(up-compare-goal remote-total < 1)
   (strategic-number sn-twenty-turns == 12)))))
=>
   (set-goal multi-group-reinforcing no)
)

