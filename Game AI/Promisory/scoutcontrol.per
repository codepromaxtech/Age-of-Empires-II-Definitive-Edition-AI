   (up-compare-goal scout-waypoint >= 3)
=>
   (up-modify-goal scout-waypoint c:- 1)
   (up-modify-goal scout-waypoint c:* -1)
   ;(up-modify-goal scout-waypoint c:* -1)
   ;(up-modify-goal movement-direction c:* -1)
