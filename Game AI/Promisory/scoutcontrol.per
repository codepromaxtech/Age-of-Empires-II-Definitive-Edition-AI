(defrule
   (timer-triggered fifteensec)
   (up-point-distance scout-group-x previous-scout-group-x < 5)
=>
   (up-modify-goal scout-waypoint g:+ movement-direction)
)

(defrule
   (timer-triggered one-min)
=>
   (up-modify-goal scout-waypoint g:+ movement-direction)
)
(defrule
   (timer-triggered fifteensec)
=>
   (up-bound-point previous-scout-group-x scout-group-x)
)

(defrule
   (taunt-detected 1 207)
=>
   (fe-break-point 1 c:== 1 -1)
   (disable-self)
)

(defrule
   (research-completed ri-bloodlines)
=>
   (set-goal temporary-goal4 4)
   (set-goal enemy-str 0)
   (up-jump-rule 1)
)


(defrule
   (true)
=>
   (set-goal temporary-goal4 3)
   (set-goal enemy-str 0)
)

(defrule
   (goal modern-scout-micro yes)
   (strategic-number sn-focus-player-number > -1)
   (players-stance focus-player enemy)
=>
   (up-full-reset-search)

   (up-set-target-point scout-group-x)
   (up-filter-distance c: -1 c: 9)
   (up-find-remote c: archer-line c: 40)
   (up-get-search-state local-total)
   (up-modify-goal remote-total c:* 3)
   (up-modify-goal enemy-str g:+ remote-total)
   (up-reset-search 0 0 1 1)
   (up-find-remote c: skirmisher-line c: 40)
   (up-get-search-state local-total)
   (up-modify-goal enemy-str g:+ remote-total)
   (up-reset-search 0 0 1 1)
   (up-find-remote c: scout-cavalry-line c: 40)
   (up-get-search-state local-total)
   (up-modify-goal remote-total c:* 5)
   (up-modify-goal enemy-str g:+ remote-total)
   (up-reset-search 0 0 1 1)
   (up-find-remote c: militiaman-line c: 40)
   (up-get-search-state local-total)
   (up-modify-goal remote-total c:* 6)
