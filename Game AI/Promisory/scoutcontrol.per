;Obtain pivot point

;We generate two candidate points which are 90 and 270 degree rotations around the obstacle
(defrule
   (strategic-number sn-twenty-turns == 12)
   (goal multi-group-reinforcing yes)
   (up-set-target-object search-remote c: 0);The search previously shouldn't be cleared
=>
   (up-get-point position-object input-origin-x)
   (up-bound-point input-point-x position-self-x)
   (up-bound-point point2-x position-self-x)
   (set-goal input-angleRad 1570);pi/2 radians
   (xs-script-call "RotateByAngleNoConvert")
   (up-bound-point point-x input-point-x)
   (up-bound-point input-point-x position-self-x)
   (set-goal input-angleRad 4711);3pi/2 radians
   (xs-script-call "RotateByAngleNoConvert")
   (up-bound-point point2-x input-point-x);Consider moving these points closer to the obstacle - could be weird on a giant map
   (up-get-point-distance point-x scout-group-x temporary-goal4)
   (up-get-point-distance point2-x scout-group-x temporary-goal5)
)

;Lerp to within 30 tiles

(defrule
   (strategic-number sn-twenty-turns == 12)
   (goal multi-group-reinforcing yes)
   (up-point-distance point-x input-origin-x > 30)
   (up-set-target-object search-remote c: 0)
=>
   (up-bound-point point-x point-x)
   (up-lerp-tiles point-x input-origin-x c: 4)
   (up-jump-rule -1)
)

(defrule
   (strategic-number sn-twenty-turns == 12)
   (goal multi-group-reinforcing yes)
   (up-point-distance point2-x input-origin-x > 30)
   (up-set-target-object search-remote c: 0)
=>
   (up-bound-point point2-x point2-x)
   (up-lerp-tiles point2-x input-origin-x c: 4)
   (up-jump-rule -1)
)
;Pick the point that is closer
(defrule
   (strategic-number sn-twenty-turns == 12)
   (goal multi-group-reinforcing yes)
   (up-compare-goal temporary-goal4 g:>= temporary-goal5)
=>
   (up-bound-point pivot-point-x point-x)
   ;(up-send-flare pivot-point-x)
)

(defrule
   (up-compare-goal temporary-goal4 g:< temporary-goal5)
   (strategic-number sn-twenty-turns == 12)
   (goal multi-group-reinforcing yes)
=>
   (up-bound-point pivot-point-x point2-x)
   ;(up-send-flare pivot-point-x)
)
;Task units not in group to group



