; ============================================================
; PHASE 12: MILITARY PRODUCTION (Strong From the Start)
; ============================================================

; --- Dark Age: Build barracks ASAP and start training ---
(defrule
    (current-age <= feudal-age)
    (building-type-count-total barracks < 1)
    (can-build barracks)
=>
    (build barracks)
)

(defrule
    (current-age <= feudal-age)
    (unit-type-count-total militiaman-line < 3)
    (can-train militiaman-line)
=>
    (train militiaman-line)
)

; --- Scout Cavalry: Train scouts throughout early game ---
(defrule
    (current-age <= feudal-age)
    (unit-type-count-total scout-cavalry-line < 1)
    (can-train scout-cavalry-line)
=>
    (train scout-cavalry-line)
)

; --- Feudal: Train scouts aggressively ---
(defrule
    (current-age <= castle-age)
    (unit-type-count-total scout-cavalry-line < 5)
    (can-train scout-cavalry-line)
=>
    (train scout-cavalry-line)
)

; --- EMERGENCY: Train militia immediately if attacked in Dark/Feudal ---
(defrule
    (town-under-attack)
    (current-age < castle-age)
    (unit-type-count-total militiaman-line < 8)
    (can-train militiaman-line)
=>
    (train militiaman-line)
)

; --- Archers: PRIMARY unit (Feudal: 10, Castle: 20) ---
(defrule
    (current-age >= feudal-age)
    (current-age < castle-age)
    (unit-type-count-total archer-line < 10)
    (can-train archer-line)
=>
    (train archer-line)
)

; --- Spearmen: SECOND priority, anti-cavalry defense ---
(defrule
    (current-age >= feudal-age)
    (unit-type-count-total spearman-line < 8)
    (can-train spearman-line)
=>
    (train spearman-line)
)

; --- Skirmishers: supplemental ranged defense (Feudal only, max 5) ---
(defrule
    (current-age >= feudal-age)
    (current-age < castle-age)
    (unit-type-count-total skirmisher-line < 5)
    (can-train skirmisher-line)
=>
    (train skirmisher-line)
)

; --- GUARANTEED MINIMUM ARMY (no resource check — always maintain these) ---
; CAVALRY FIRST: These rules fire with top priority to ensure mounted units.
(defrule
    (current-age >= feudal-age)
    (unit-type-count-total scout-cavalry-line < 3)
    (can-train scout-cavalry-line)
=>
    (train scout-cavalry-line)
)

(defrule
    (current-age >= castle-age)
    (unit-type-count-total knight-line < 10)
    (can-train knight-line)
=>
    (train knight-line)
)

(defrule
    (current-age >= castle-age)
    (unit-type-count-total scout-cavalry-line < 8)
    (can-train scout-cavalry-line)
=>
    (train scout-cavalry-line)
)

; Infantry & ranged minimum
(defrule
    (current-age >= feudal-age)
    (unit-type-count-total archer-line < 5)
    (can-train archer-line)
=>
    (train archer-line)
)

(defrule
    (current-age >= feudal-age)
    (unit-type-count-total spearman-line < 5)
    (can-train spearman-line)
=>
    (train spearman-line)
)

; --- Castle Age: Scale up the core army fast ---
(defrule
    (current-age >= castle-age)
    (unit-type-count-total archer-line < 20)
    (can-train archer-line)
=>
    (train archer-line)
)

(defrule
    (current-age >= castle-age)
    (unit-type-count-total spearman-line < 12)
    (can-train spearman-line)
=>
    (train spearman-line)
)

; --- Light Cavalry / Hussars: zero-gold raiding & meatshield ---
(defrule
    (current-age >= castle-age)
    (unit-type-count-total scout-cavalry-line < 10)
    (can-train scout-cavalry-line)
=>
    (train scout-cavalry-line)
)

(defrule
    (current-age >= imperial-age)
    (unit-type-count-total scout-cavalry-line < 20)
    (can-train scout-cavalry-line)
=>
    (train scout-cavalry-line)
)

; --- Cavalry Archers: mobile ranged DPS (small group only, focus on core army) ---
(defrule
    (current-age >= castle-age)
    (unit-type-count-total cavalry-archer-line < 5)
    (can-train cavalry-archer-line)
=>
    (train cavalry-archer-line)
)

(defrule
    (current-age >= imperial-age)
    (unit-type-count-total cavalry-archer-line < 10)
    (can-train cavalry-archer-line)
=>
    (train cavalry-archer-line)
)

; --- Knights: mobile counter-attack force ---
(defrule
    (current-age >= castle-age)
    (unit-type-count-total knight-line < 10)
    (can-train knight-line)
=>
    (train knight-line)
)

(defrule
    (current-age >= imperial-age)
    (unit-type-count-total knight-line < 20)
    (can-train knight-line)
=>
    (train knight-line)
)

; --- Mangonels / Onagers: area denial (SMALL numbers, expensive) ---
(defrule
    (current-age >= castle-age)
    (unit-type-count-total mangonel-line < 2)
    (can-train mangonel-line)
=>
    (train mangonel-line)
)

(defrule
    (current-age >= imperial-age)
    (unit-type-count-total mangonel-line < 4)
    (can-train mangonel-line)
=>
    (train mangonel-line)
)

; --- Scorpions: only in Imperial, small support group ---
(defrule
    (current-age >= imperial-age)
    (unit-type-count-total scorpion-line < 4)
    (can-train scorpion-line)
=>
    (train scorpion-line)
)

; --- Battering Rams: siege for retaliatory strikes (max 2) ---
(defrule
    (current-age >= castle-age)
    (unit-type-count-total battering-ram-line < 2)
    (can-train battering-ram-line)
=>
    (train battering-ram-line)
)

; --- Trebuchets: essential push unit (max 3) ---
(defrule
    (current-age >= imperial-age)
    (unit-type-count-total trebuchet < 3)
    (can-train trebuchet)
=>
    (train trebuchet)
)

; --- Bombard Cannons: powerful but expensive (max 2) ---
(defrule
    (current-age >= imperial-age)
    (unit-type-count-total bombard-cannon < 2)
    (can-train bombard-cannon)
=>
    (train bombard-cannon)
)

; --- Champion: beefy front-line defense ---
(defrule
    (current-age >= imperial-age)
    (unit-type-count-total militiaman-line < 20)
    (can-train militiaman-line)
=>
    (train militiaman-line)
)

; --- Hussars: rapid counter-raiding force (removed: redundant with line ~1946 cap of 25) ---

; --- Hand Cannoneers: powerful ranged infantry ---
(defrule
    (current-age >= imperial-age)
    (unit-type-count-total hand-cannoneer < 10)
    (can-train hand-cannoneer)
=>
    (train hand-cannoneer)
)

; ============================================================
; PHASE 13: MONKS & RELICS (Temple Artifacts)
; ============================================================

(defrule
    (current-age >= castle-age)
    (building-type-count-total monastery < 1)
    (can-build monastery)
=>
    (build monastery)
)

; Second monastery in Imperial for faster monk production
(defrule
    (current-age >= imperial-age)
    (building-type-count-total monastery < 2)
    (can-build monastery)
=>
    (build monastery)
)

(defrule
    (current-age >= castle-age)
    (unit-type-count-total monk < 5)
    (can-train monk)
=>
    (train monk)
)

(defrule
    (current-age >= imperial-age)
    (unit-type-count-total monk < 8)
    (can-train monk)
=>
    (train monk)
)

; Monks seek relics across maximum distance
(defrule
    (current-age >= castle-age)
=>
    (set-strategic-number sn-relic-return-distance 200)
    (disable-self)
)

; ============================================================
; PHASE 14: DEFENSIVE COMBAT LOGIC
; ============================================================

; --- IMMEDIATE: Respond with ANY available military (even 1 soldier) ---
(defrule
    (town-under-attack)
    (military-population >= 1)
=>
    (set-strategic-number sn-number-attack-groups 1)
    (set-strategic-number sn-minimum-attack-group-size 1)
    (set-strategic-number sn-maximum-attack-group-size 10)
    (set-strategic-number sn-maximum-town-size 40)
    (set-strategic-number sn-percent-attack-soldiers 100)
    (attack-now)
)

; --- Small force: organized defense ---
(defrule
    (town-under-attack)
    (military-population >= 8)
=>
    (set-strategic-number sn-number-attack-groups 2)
    (set-strategic-number sn-minimum-attack-group-size 4)
    (set-strategic-number sn-maximum-attack-group-size 20)
    (set-strategic-number sn-maximum-town-size 80)
    (set-strategic-number sn-percent-attack-soldiers 80)
    (attack-now)
)

; --- Full retaliation: massive army unleashed ---
(defrule
    (town-under-attack)
    (military-population >= 30)
=>
    (set-strategic-number sn-number-attack-groups 3)
    (set-strategic-number sn-minimum-attack-group-size 10)
    (set-strategic-number sn-maximum-attack-group-size 30)
    (set-strategic-number sn-maximum-town-size 150)
    (set-strategic-number sn-percent-attack-soldiers 70)
    (attack-now)
)

; --- Overwhelming force: counter-offensive ---
(defrule
    (town-under-attack)
    (military-population >= 60)
=>
    (set-strategic-number sn-number-attack-groups 5)
    (set-strategic-number sn-minimum-attack-group-size 12)
    (set-strategic-number sn-maximum-attack-group-size 40)
    (set-strategic-number sn-maximum-town-size 255)
    (set-strategic-number sn-percent-attack-soldiers 80)
    (attack-now)
)

; --- Reset to defensive posture when no longer attacked ---
(defrule
    (not (town-under-attack))
    (strategic-number sn-number-attack-groups > 0)
=>
    (set-strategic-number sn-number-attack-groups 0)
    (set-strategic-number sn-minimum-attack-group-size 20)
    (set-strategic-number sn-maximum-attack-group-size 40)
    (set-strategic-number sn-maximum-town-size 80)
    (set-strategic-number sn-percent-attack-soldiers 0)
    (up-reset-attack-now)
)

; ============================================================
; PHASE 15: TARGET PLAYER SELECTION
; ============================================================

; --- Initial target: closest enemy ---
(defrule
    (true)
=>
    (up-find-player enemy find-closest gl-target-player)
    (up-modify-sn sn-target-player-number g:= gl-target-player)
    (up-modify-sn sn-focus-player-number g:= gl-target-player)
    (disable-self)
)

; --- Re-evaluate target every 2 minutes (attack the nearest threat) ---
(defrule
    (game-time > 120)
    (players-building-count any-enemy >= 1)
=>
    (up-find-player enemy find-closest gl-target-player)
    (up-modify-sn sn-target-player-number g:= gl-target-player)
    (up-modify-sn sn-focus-player-number g:= gl-target-player)
)

; ============================================================
; PHASE 16: PROACTIVE AGGRESSION (Not Just Defensive)
; ============================================================

; --- Feudal Age: Early pressure with small army ---
(defrule
    (current-age == feudal-age)
    (military-population >= 8)
    (game-time > 660)
    (not (town-under-attack))
=>
    (set-strategic-number sn-number-attack-groups 1)
    (set-strategic-number sn-minimum-attack-group-size 5)
    (set-strategic-number sn-maximum-attack-group-size 15)
    (set-strategic-number sn-percent-attack-soldiers 50)
    (attack-now)
    (disable-self)
)

; --- Castle Age: Periodic pressure every ~3 minutes ---
(defrule
    (current-age == castle-age)
    (military-population >= 20)
    (game-time > 1200)
    (not (town-under-attack))
=>
    (set-strategic-number sn-number-attack-groups 2)
    (set-strategic-number sn-minimum-attack-group-size 10)
    (set-strategic-number sn-maximum-attack-group-size 25)
    (set-strategic-number sn-percent-attack-soldiers 50)
    (attack-now)
    (disable-self)
)

; --- Imperial Age: Full offensive with overwhelming force ---
(defrule
    (current-age >= imperial-age)
    (military-population >= 40)
    (game-time > 1800)
    (not (town-under-attack))
=>
    (set-strategic-number sn-number-attack-groups 3)
    (set-strategic-number sn-minimum-attack-group-size 12)
    (set-strategic-number sn-maximum-attack-group-size 35)
    (set-strategic-number sn-percent-attack-soldiers 60)
    (attack-now)
    (disable-self)
)

; --- Late game: continuous pressure with massive army ---
(defrule
    (current-age >= imperial-age)
    (military-population >= 80)
    (not (town-under-attack))
=>
    (set-strategic-number sn-number-attack-groups 5)
    (set-strategic-number sn-minimum-attack-group-size 15)
    (set-strategic-number sn-maximum-attack-group-size 40)
    (set-strategic-number sn-percent-attack-soldiers 75)
    (attack-now)
)

; ============================================================
; PHASE 17: ADAPTIVE ARMY COMPOSITION
; ============================================================

; --- Counter heavy cavalry: train more spearmen ---
(defrule
    (current-age >= castle-age)
    (players-unit-type-count target-player knight-line >= 5)
    (unit-type-count-total spearman-line < 30)
    (can-train spearman-line)
=>
    (train spearman-line)
)

; --- Counter heavy cavalry: train camels if available ---
(defrule
    (current-age >= castle-age)
    (players-unit-type-count target-player knight-line >= 8)
    (unit-type-count-total camel-line < 10)
    (can-train camel-line)
=>
    (train camel-line)
)

; --- Counter mass archers: train more skirmishers ---
(defrule
    (current-age >= feudal-age)
    (players-unit-type-count target-player archer-line >= 5)
    (unit-type-count-total skirmisher-line < 30)
    (can-train skirmisher-line)
=>
    (train skirmisher-line)
)

; --- Counter mass archers: train mangonels ---
(defrule
    (current-age >= castle-age)
    (players-unit-type-count target-player archer-line >= 10)
    (unit-type-count-total mangonel-line < 3)
    (can-train mangonel-line)
=>
    (train mangonel-line)
)

; --- Counter infantry: train more archers ---
(defrule
    (current-age >= feudal-age)
    (players-unit-type-count target-player militiaman-line >= 5)
    (unit-type-count-total archer-line < 30)
    (can-train archer-line)
=>
    (train archer-line)
)

; --- Counter infantry: train knights ---
(defrule
    (current-age >= castle-age)
    (players-unit-type-count target-player militiaman-line >= 8)
    (unit-type-count-total knight-line < 15)
    (can-train knight-line)
=>
    (train knight-line)
)

; --- Counter siege: train cavalry to raid ---
(defrule
    (current-age >= castle-age)
    (players-unit-type-count target-player mangonel-line >= 2)
    (unit-type-count-total scout-cavalry-line < 15)
    (can-train scout-cavalry-line)
=>
    (train scout-cavalry-line)
)

; ============================================================
; PHASE 18: MARKET & TRADE (Smart Commerce)
; ============================================================

; --- Market: ALWAYS keep at least 1 (critical for trade income) ---
(defrule
    (current-age >= feudal-age)
    (building-type-count-total market < 1)
    (can-build market)
=>
    (build market)
    (chat-to-all "ZULFIKAR: Market is essential! Rebuilding immediately!")
)

; --- Protect market: rebuild if destroyed in Castle+ ---
(defrule
    (current-age >= castle-age)
    (building-type-count-total market < 1)
    (can-build market)
=>
    (build market)
)

; --- Build 2nd market in Imperial for trade flexibility ---
(defrule
    (current-age >= imperial-age)
    (building-type-count-total market < 2)
    (can-build market)
=>
    (build market)
)

; --- Trade Carts: generate gold through trade ---
; In team games, trade with ally market
(defrule
    (current-age >= castle-age)
    (unit-type-count-total trade-cart < 10)
    (players-building-type-count any-ally market >= 1)
    (can-train trade-cart)
=>
    (train trade-cart)
)

(defrule
    (current-age >= imperial-age)
    (unit-type-count-total trade-cart < 25)
    (players-building-type-count any-ally market >= 1)
    (can-train trade-cart)
=>
    (train trade-cart)
)

; --- Solo games: buy/sell at market for gold when no allies ---
(defrule
    (current-age >= castle-age)
    (gold-amount < 100)
    (food-amount > 500)
    (can-sell-commodity food)
=>
    (sell-commodity food)
)

(defrule
    (current-age >= castle-age)
    (gold-amount < 100)
    (wood-amount > 500)
    (can-sell-commodity wood)
=>
    (sell-commodity wood)
)

; --- Trade Cogs: when ally dock exists ---
(defrule
    (current-age >= castle-age)
    (unit-type-count-total trade-cog < 5)
    (players-building-type-count any-ally dock >= 1)
    (can-train trade-cog)
=>
    (train trade-cog)
)

; --- Sell excess resources (price-sensitive) ---
(defrule
    (wood-amount > 1800)
    (commodity-selling-price wood > 35)
    (can-sell-commodity wood)
=>
    (sell-commodity wood)
)

(defrule
    (food-amount > 1800)
    (commodity-selling-price food > 35)
    (can-sell-commodity food)
=>
    (sell-commodity food)
)

(defrule
    (stone-amount > 1000)
    (commodity-selling-price stone >= 125)
    (can-sell-commodity stone)
=>
    (sell-commodity stone)
)

; --- Sell for age-ups when gold is short ---
(defrule
    (gold-amount < 200)
    (food-amount > 600)
    (research-available castle-age)
    (can-sell-commodity food)
=>
    (sell-commodity food)
)

(defrule
    (gold-amount < 200)
    (wood-amount > 600)
    (research-available castle-age)
    (can-sell-commodity wood)
=>
    (sell-commodity wood)
)

(defrule
    (gold-amount < 400)
    (food-amount > 800)
    (research-available imperial-age)
    (can-sell-commodity food)
=>
    (sell-commodity food)
)

; --- Emergency gold shortfall ---
(defrule
    (gold-amount < 100)
    (wood-amount > 500)
    (can-sell-commodity wood)
=>
    (sell-commodity wood)
)

(defrule
    (gold-amount < 100)
    (food-amount > 500)
    (can-sell-commodity food)
=>
    (sell-commodity food)
)

; --- Buy food if starving ---
(defrule
    (food-amount < 80)
    (gold-amount > 400)
    (can-buy-commodity food)
=>
    (buy-commodity food)
)

; --- Buy stone for castles/towers ---
(defrule
    (stone-amount < 200)
    (gold-amount > 500)
    (building-type-count-total castle < 2)
    (can-buy-commodity stone)
=>
    (buy-commodity stone)
)

; --- Emergency wood buy ---
(defrule
    (wood-amount < 60)
    (gold-amount > 400)
    (can-buy-commodity wood)
=>
    (buy-commodity wood)
)

; ============================================================
; PHASE 19: DEFENSIVE COMBAT LOGIC
; ============================================================

; --- Retaliation: small force counter when attacked ---
(defrule
    (town-under-attack)
    (military-population >= 10)
=>
    (set-strategic-number sn-number-attack-groups 1)
    (set-strategic-number sn-minimum-attack-group-size 8)
    (set-strategic-number sn-maximum-attack-group-size 20)
    (set-strategic-number sn-maximum-town-size 60)
    (set-strategic-number sn-percent-attack-soldiers 50)
    (chat-to-all "ZULFIKAR: Defending the homeland!")
    (attack-now)
)

; --- Full retaliation: massive army unleashed ---
(defrule
    (town-under-attack)
    (military-population >= 40)
=>
    (set-strategic-number sn-number-attack-groups 3)
    (set-strategic-number sn-minimum-attack-group-size 12)
    (set-strategic-number sn-maximum-attack-group-size 30)
    (set-strategic-number sn-maximum-town-size 150)
    (set-strategic-number sn-percent-attack-soldiers 65)
    (chat-to-all "ZULFIKAR: Unleashing the full garrison!")
    (attack-now)
)

; --- Overwhelming force: counter-offensive ---
(defrule
    (town-under-attack)
    (military-population >= 80)
=>
    (set-strategic-number sn-number-attack-groups 5)
    (set-strategic-number sn-minimum-attack-group-size 15)
    (set-strategic-number sn-maximum-attack-group-size 40)
    (set-strategic-number sn-maximum-town-size 255)
    (set-strategic-number sn-percent-attack-soldiers 80)
    (chat-to-all "ZULFIKAR: Total war. Annihilating threat.")
    (attack-now)
)

; --- Reset to defensive posture when no longer attacked ---
(defrule
    (not (town-under-attack))
    (strategic-number sn-number-attack-groups > 0)
    (current-age < imperial-age)
=>
    (set-strategic-number sn-number-attack-groups 0)
    (set-strategic-number sn-minimum-attack-group-size 20)
    (set-strategic-number sn-maximum-attack-group-size 40)
    (set-strategic-number sn-maximum-town-size 80)
    (set-strategic-number sn-percent-attack-soldiers 0)
    (up-reset-attack-now)
)

; ============================================================
; PHASE 20: POPULATION & HOUSING SAFETY
; ============================================================

; Emergency housing: prevent getting population capped
(defrule
    (housing-headroom < 3)
    (population-headroom > 0)
    (can-build house)
=>
    (build house)
)

; ============================================================
; PHASE 21: MISSING UPGRADES
; ============================================================

; --- Cavalry Archer Upgrade ---
(defrule
    (can-research ri-heavy-cavalry-archer)
=>
    (research ri-heavy-cavalry-archer)
)

; --- Siege Upgrades ---
(defrule
    (can-research ri-siege-ram)
=>
    (research ri-siege-ram)
)

(defrule
    (can-research ri-siege-onager)
=>
    (research ri-siege-onager)
)

; --- Naval Upgrades: moved to Dock section above ---


; --- Unique Unit Upgrade (civ-specific) ---
(defrule
    (can-research my-unique-unit-upgrade)
=>
    (research my-unique-unit-upgrade)
)

; --- Unique Tech Upgrades ---
(defrule
    (can-research my-unique-research)
=>
    (research my-unique-research)
)

(defrule
    (can-research my-castle-unique-research)
=>
    (research my-castle-unique-research)
)

; --- Spies (late game info) ---
(defrule
    (current-age >= imperial-age)
    (gold-amount > 2000)
    (can-research ri-spies)
=>
    (research ri-spies)
)

; ============================================================
; PHASE 22: LATE GAME SCALING
; ============================================================

; Scale up defend groups in Imperial for stronger turtle
(defrule
    (current-age >= imperial-age)
    (military-population >= 60)
=>
    (set-strategic-number sn-number-defend-groups 5)
    (set-strategic-number sn-minimum-defend-group-size 8)
    (set-strategic-number sn-maximum-defend-group-size 30)
    (disable-self)
)

; Increase town size in late game for broader control
(defrule
    (current-age >= imperial-age)
    (game-time > 2400)
    (not (town-under-attack))
=>
    (set-strategic-number sn-maximum-town-size 100)
    (set-strategic-number sn-safe-town-size 60)
    (disable-self)
)

; ============================================================
; PHASE 23: EARLY WALLING (Stone Walls Only — No Wooden Gates)
; ============================================================
; NOTE: Palisade walls create PALISADE GATES (wooden) which are weak.
; This is hardcoded engine behavior that sn-gate-type-for-wall cannot override.
; ZULFIKAR uses ONLY stone walls to ensure all gates are stone gates.

; --- Feudal Age: Stone wall perimeter 1 as soon as stone is available ---
(defrule
    (current-age >= feudal-age)
    (stone-amount > 100)
    (can-build-wall 1 stone-wall)
=>
    (enable-wall-placement 1)
    (build-wall 1 stone-wall)
)

; --- Feudal Age: If no stone, use palisade but WITHOUT gates ---
; (Palisade wall segments only — no build-gate call = no wooden gates)
(defrule
    (current-age >= feudal-age)
    (stone-amount < 100)
    (not (map-type arena))
    (not (map-type fortress))
    (not (map-type black-forest))
    (can-build-wall 1 palisade-wall)
=>
    (enable-wall-placement 1)
    (build-wall 1 palisade-wall)
)

; ============================================================
; PHASE 24: VILLAGER GARRISON DURING RAIDS
; ============================================================

; --- Garrison villagers in TC when under attack (human instinct) ---
(defrule
    (town-under-attack)
    (building-type-count town-center >= 1)
=>
    (set-strategic-number sn-maximum-garrison-fill 15)
    (set-strategic-number sn-number-garrison-units 10)
    (set-strategic-number sn-disable-villager-garrison 0)
)

; --- Ungarrison villagers when safe ---
(defrule
    (not (town-under-attack))
=>
    (set-strategic-number sn-number-garrison-units 0)
)

; ============================================================
; PHASE 25: FISH TRAPS (Sustainable Water Economy)
; ============================================================

; --- Build fish traps when dock exists and economy needs food ---
(defrule
    (current-age >= feudal-age)
    (building-type-count-total dock >= 1)
    (building-type-count-total fish-trap < 5)
    (wood-amount > 200)
    (food-amount < 500)
    (can-build fish-trap)
=>
    (build fish-trap)
)

(defrule
    (current-age >= castle-age)
    (building-type-count-total dock >= 1)
    (building-type-count-total fish-trap < 15)
    (wood-amount > 300)
    (food-amount < 400)
    (can-build fish-trap)
=>
    (build fish-trap)
)

; ============================================================
; PHASE 26: ALLY SUPPORT (Team Player Behavior)
; ============================================================

; --- Tribute food to ally if they're starving and we have excess ---
(defrule
    (current-age >= castle-age)
    (food-amount > 1500)
    (player-in-game any-ally)
    (players-civilian-population any-ally < 10)
=>
    (tribute-to-player any-ally food 300)
    (chat-to-player any-ally "ZULFIKAR: Sending food support!")
)

; --- Tribute gold to ally if we have excess ---
(defrule
    (current-age >= castle-age)
    (gold-amount > 1500)
    (player-in-game any-ally)
    (players-military-population any-ally < 5)
=>
    (tribute-to-player any-ally gold 200)
    (chat-to-player any-ally "ZULFIKAR: Gold incoming, build army!")
)

; ============================================================
; PHASE 27: WONDER & RELIC VICTORY AWARENESS
; ============================================================

; --- Attack enemies building a Wonder immediately ---
(defrule
    (players-building-type-count any-enemy wonder >= 1)
    (military-population >= 5)
=>
    (set-strategic-number sn-number-attack-groups 5)
    (set-strategic-number sn-minimum-attack-group-size 1)
    (set-strategic-number sn-maximum-attack-group-size 200)
    (set-strategic-number sn-percent-attack-soldiers 100)
    (chat-to-all "ZULFIKAR: Wonder spotted! ALL-IN ATTACK!")
    (attack-now)
)

; --- Build our own Wonder if economy allows ---
(defrule
    (current-age >= imperial-age)
    (food-amount > 1500)
    (wood-amount > 1500)
    (gold-amount > 1500)
    (stone-amount > 1500)
    (building-type-count-total wonder < 1)
    (can-build wonder)
=>
    (build wonder)
    (chat-to-all "ZULFIKAR: Constructing a Wonder!")
)

; ============================================================
; PHASE 28: PERSONALITY & TAUNTS (Human-like Chat)
; ============================================================

; --- Chat on reaching Castle Age ---
(defrule
    (current-age == castle-age)
=>
    (chat-to-all "ZULFIKAR: Castle Age reached. Prepare yourselves.")
    (disable-self)
)

; --- Chat on reaching Imperial ---
(defrule
    (current-age == imperial-age)
=>
    (chat-to-all "ZULFIKAR: Imperial Age. The endgame begins.")
    (disable-self)
)

; --- Chat when collecting all relics ---
(defrule
    (hold-relics)
=>
    (chat-to-all "ZULFIKAR: All relics secured. Gold flows eternal.")
    (disable-self)
)

; --- Taunt the enemy when winning ---
(defrule
    (current-age >= imperial-age)
    (military-population >= 100)
    (players-military-population any-enemy < 20)
=>
    (chat-to-all "ZULFIKAR: Your army crumbles. Surrender is wise.")
    (disable-self)
)

; --- Chat when rebuilding after a raid ---
(defrule
    (town-under-attack)
    (military-population < 10)
    (unit-type-count-total villager >= 20)
=>
    (chat-to-all "ZULFIKAR: You will pay for that.")
    (disable-self)
)

; ============================================================
; PHASE 29: NAVAL EXPLORATION (Water Map Awareness)
; ============================================================

; --- Explore water with boats on water maps ---
(defrule
    (current-age >= feudal-age)
    (building-type-count-total dock >= 1)
=>
    (set-strategic-number sn-number-boat-explore-groups 1)
    (set-strategic-number sn-minimum-boat-explore-group-size 1)
    (set-strategic-number sn-number-boat-attack-groups 1)
    (set-strategic-number sn-minimum-boat-attack-group-size 5)
    (disable-self)
)

; --- Increase naval aggression in Castle Age ---
(defrule
    (current-age >= castle-age)
    (building-type-count-total dock >= 2)
=>
    (set-strategic-number sn-number-boat-attack-groups 2)
    (set-strategic-number sn-minimum-boat-attack-group-size 8)
    (set-strategic-number sn-maximum-boat-attack-group-size 20)
    (set-strategic-number sn-percent-attack-boats 50)
    (disable-self)
)

; --- Imperial naval dominance ---
(defrule
    (current-age >= imperial-age)
    (building-type-count-total dock >= 3)
=>
    (set-strategic-number sn-number-boat-attack-groups 3)
    (set-strategic-number sn-minimum-boat-attack-group-size 10)
    (set-strategic-number sn-maximum-boat-attack-group-size 40)
    (set-strategic-number sn-percent-attack-boats 60)
    (disable-self)
)

; ============================================================
; PHASE 30: TRANSPORT SHIPS (Cross-water Attacks)
; ============================================================

; --- Build transport ships on water/island maps ---
(defrule
    (current-age >= feudal-age)
    (or (map-type islands) (map-type team-islands))
    (unit-type-count-total transport-ship < 2)
    (can-train transport-ship)
=>
    (train transport-ship)
)

(defrule
    (current-age >= castle-age)
    (building-type-count-total dock >= 1)
    (unit-type-count-total transport-ship < 3)
    (can-train transport-ship)
=>
    (train transport-ship)
)

; ============================================================
; PHASE 31: RESIGN LOGIC (Graceful Surrender)
; ============================================================

; --- Resign when totally crushed ---
(defrule
    (game-time > 1200)
    (unit-type-count-total villager < 1)
    (military-population < 3)
    (building-type-count-total town-center < 1)
=>
    (chat-to-all "ZULFIKAR: GG. Well played.")
    (resign)
)

; --- Resign when no economy and no hope ---
(defrule
    (game-time > 1800)
    (unit-type-count-total villager < 3)
    (military-population < 5)
    (building-type-count-total castle < 1)
    (building-type-count-total town-center < 1)
=>
    (chat-to-all "ZULFIKAR: No recovery possible. GG.")
    (resign)
)

; ============================================================
; END OF ZULFIKAR AI SCRIPT
; ============================================================

