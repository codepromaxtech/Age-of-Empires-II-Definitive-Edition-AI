(defrule
    (up-research-status c: ri-fletching < research-complete)
    (up-research-status c: ri-fletching != research-pending)
    (can-research ri-fletching) ; Backup check
=>
    (up-jump-rule 11) ; Skip all other blacksmith tech until Fletching is researching/done
)

