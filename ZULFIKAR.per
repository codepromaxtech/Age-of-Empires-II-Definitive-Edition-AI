    (current-age >= imperial-age)
    (building-type-count-total bombard-tower < 10)
    (stone-amount > 300)
    (gold-amount > 300)
    (can-build bombard-tower)
=>
    (build bombard-tower)
)

; --- Castles (PRIORITY: Build ASAP for defense and unique units) ---
