; ============================================================
; PHASE 2: VILLAGER PRODUCTION (Zero Idle Time)
; ============================================================

(defrule
    (current-age == dark-age)
    (unit-type-count-total villager < gl-dark-age-vils)
    (can-train villager)
=>
    (train villager)
)

; ============================================================
; PHASE 3: DIFFICULTY SCALING (Hardest/Extreme Mode Support)
; ============================================================

; On Hardest/Extreme, AI reaction times are superhuman
(defrule
    (difficulty <= hard) ; hard, hardest, extreme
=>
    (set-strategic-number sn-enemy-sighted-response-distance 25)
    (set-strategic-number sn-percent-enemy-sighted-response 100)
    (set-strategic-number sn-defense-distance 25)
    (disable-self)
)

; Hardest/Extreme Resource Trickle (to simulate perfect human APM macro)
(defrule
    (difficulty <= hardest) ; hardest, extreme
    (timer-triggered 5)
=>
    (up-cc-add-resource c: wood g: 15)
    (up-cc-add-resource c: food g: 15)
    (up-cc-add-resource c: gold g: 15)
    (up-cc-add-resource c: stone g: 5)
    (disable-timer 5)
    (enable-timer 5 30) ; Trickle every 30 seconds
)

(defrule
    (difficulty <= hardest)
    (not (timer-triggered 5))
=>
    (enable-timer 5 30)
    (disable-self)
)

(defrule
    (current-age == feudal-age)
    (unit-type-count-total villager < gl-feudal-age-vils)
    (can-train villager)
=>
    (train villager)
)

(defrule
    (current-age == castle-age)
    (unit-type-count-total villager < gl-castle-age-vils)
    (can-train villager)
=>
    (train villager)
)

(defrule
    (current-age >= imperial-age)
    (unit-type-count-total villager < gl-imperial-age-vils)
    (can-train villager)
=>
    (train villager)
)

