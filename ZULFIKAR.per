; ============================================================
; PHASE 9: BEAUTIFUL FORTRESS - DOUBLE STONE WALLS
; ============================================================

; In Castle Age, we begin our massive stone fortification.
; We use Perimeter 1 (Inner) and Perimeter 2 (Outer) to create a double stone wall with a gap.
; If the map layout forces them together, the engine naturally merges them into a single double-thick wall.

; --- Island Map Detection & Coastal Wall Push ---
; If on an island, temporarily expand town size to maximum (255) so the wall builder reaches the coastline
(defrule
    (current-age >= castle-age)
    (or (map-type islands) (map-type team-islands))
=>
    (set-strategic-number sn-maximum-town-size 255) ; Push walls to the sea
    (enable-wall-placement 1)
    (enable-wall-placement 2)
    (chat-to-all "ZULFIKAR: Securing island coastline with double fortifications...")
    (disable-self)
)

; --- Standard Land Map Wall Push ---
(defrule
    (current-age >= castle-age)
    (not (map-type islands))
    (not (map-type team-islands))
=>
    (enable-wall-placement 1)
    (enable-wall-placement 2)
    (chat-to-all "ZULFIKAR: Commencing double stone wall fortifications...")
    (disable-self)
)

; --- Restore Economic Stability ---
; After wall placement is locked in, drop the town size back down so villagers don't scatter
(defrule
    (current-age >= castle-age)
    (or (map-type islands) (map-type team-islands))
    (strategic-number sn-maximum-town-size == 255)
=>
    (set-strategic-number sn-maximum-town-size 45) ; Keep eco tight, walls stay on coast
    (set-strategic-number sn-camp-max-distance 30)
)

; --- Perimeter 1 (Inner Stone Wall) ---
(defrule
    (current-age >= castle-age)
    (stone-amount > 150)
    (can-build-wall 1 stone-wall)
=>
    (set-strategic-number sn-gate-type-for-wall 1)
    (build-wall 1 stone-wall)
)

; Build stone gate at inner perimeter (1 gate only for trade route)
(defrule
    (current-age >= castle-age)
    (stone-amount > 150)
    (building-type-count-total gate < 1)
    (can-build-gate 1)
=>
    (set-strategic-number sn-gate-type-for-wall 1)
    (build-gate 1)
)

; --- Perimeter 2 (Outer Stone Wall) ---
(defrule
    (current-age >= castle-age)
    (stone-amount > 150)
    (can-build-wall 2 stone-wall)
=>
    (set-strategic-number sn-gate-type-for-wall 1)
    (build-wall 2 stone-wall)
)

; Build stone gate at outer perimeter (1 gate only)
(defrule
    (current-age >= castle-age)
    (stone-amount > 150)
    (building-type-count-total gate < 2)
    (can-build-gate 2)
=>
    (set-strategic-number sn-gate-type-for-wall 1)
    (build-gate 2)
)

; --- Towers (Only build when economy is stable) ---
(defrule
    (current-age >= feudal-age)
    (building-type-count-total watch-tower < 6)
    (wood-amount > 200)
    (stone-amount > 150)
    (can-build watch-tower)
=>
    (build watch-tower)
)

(defrule
    (current-age >= castle-age)
    (building-type-count-total watch-tower < 12)
    (wood-amount > 250)
    (stone-amount > 200)
    (can-build watch-tower)
=>
    (build watch-tower)
)

(defrule
    (current-age >= imperial-age)
    (building-type-count-total watch-tower < 20)
    (wood-amount > 300)
    (stone-amount > 250)
    (can-build watch-tower)
=>
    (build watch-tower)
)

; --- Bombard Towers (Ultimate plugging, high cost) ---
