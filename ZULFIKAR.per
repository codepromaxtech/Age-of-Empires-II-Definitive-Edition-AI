; ============================================================
; PHASE 1: INITIALIZATION
; ============================================================

(defrule
    (true)
=>
    ; --- Building System ---
    (set-strategic-number sn-enable-new-building-system 1)
    (set-strategic-number sn-percent-building-cancellation 20)
    (set-strategic-number sn-cap-civilian-builders 15)
    (set-strategic-number sn-percent-civilian-builders 35)

    ; --- Training & Research Queuing (queue units/techs faster) ---
    (set-strategic-number sn-enable-training-queue 2)
    (set-strategic-number sn-enable-research-queue 1)

    ; --- Exploration ---
    (set-strategic-number sn-total-number-explorers 1)
    (set-strategic-number sn-number-explore-groups 1)
    (set-strategic-number sn-initial-exploration-required 0)
    (set-strategic-number sn-percent-exploration-required 50)
    (set-strategic-number sn-home-exploration-time 300)

    ; --- Economy (Dark Age: heavy food for fast Feudal) ---
    (set-strategic-number sn-food-gatherer-percentage 70)
    (set-strategic-number sn-wood-gatherer-percentage 20)
    (set-strategic-number sn-gold-gatherer-percentage 0)
    (set-strategic-number sn-stone-gatherer-percentage 10)
    (set-strategic-number sn-percent-civilian-gatherers 100)

    ; --- Boar Hunting & Foraging ---
    (set-strategic-number sn-enable-boar-hunting 2)
    (set-strategic-number sn-minimum-boar-hunt-group-size 3)
    (set-strategic-number sn-minimum-number-hunters 4)
    (set-strategic-number sn-livestock-to-town-center 1)
    (disable-self)
)

(defrule
    (true)
=>
    ; --- Town Layout & Safe Zone (Structured Grid Building) ---
    (set-strategic-number sn-maximum-town-size 30)
    (set-strategic-number sn-minimum-town-size 14)
    (set-strategic-number sn-safe-town-size 38)
    (set-strategic-number sn-placement-zone-size 7)
    (set-strategic-number sn-placement-fail-delta 2)
    (set-strategic-number sn-camp-max-distance 20)
    (set-strategic-number sn-mill-max-distance 20)
    (set-strategic-number sn-lumber-camp-max-distance 25)
    (set-strategic-number sn-mining-camp-max-distance 25)

    ; --- Dropsite Optimization ---
    (set-strategic-number sn-food-dropsite-distance 4)
    (set-strategic-number sn-wood-dropsite-distance 4)
    (set-strategic-number sn-gold-dropsite-distance 4)
    (set-strategic-number sn-stone-dropsite-distance 4)
    (set-strategic-number sn-dropsite-separation-distance 8)

    ; --- Building Repair (MAX: villagers auto-repair ALL damaged buildings) ---
    (set-strategic-number sn-object-repair-level 32767)

    ; --- Defensive Posture (NO unprovoked attacks) ---
    (set-strategic-number sn-percent-enemy-sighted-response 100)
    (set-strategic-number sn-enemy-sighted-response-distance 12)
    (set-strategic-number sn-number-attack-groups 0)
    (set-strategic-number sn-minimum-attack-group-size 20)
    (set-strategic-number sn-maximum-attack-group-size 40)
    (set-strategic-number sn-number-defend-groups 3)
    (set-strategic-number sn-minimum-defend-group-size 5)
    (set-strategic-number sn-maximum-defend-group-size 20)
    (set-strategic-number sn-defense-distance 15)
    (set-strategic-number sn-sentry-distance 15)
    (set-strategic-number sn-sentry-distance-variation 4)
    (disable-self)
)

(defrule
    (true)
=>
    ; --- Attack Intelligence & Patrol ---
    (set-strategic-number sn-attack-intelligence 1)
    (set-strategic-number sn-enable-patrol-attack 1)
    (set-strategic-number sn-initial-attack-delay 0)
    (set-strategic-number sn-initial-attack-delay-type 0)
    (set-strategic-number sn-ignore-attack-group-under-attack 1)
    (set-strategic-number sn-allow-adjacent-dropsites 1) ; Allows tighter lumber camps to clear out woodlines faster

    ; --- Garrison Control ---
    (set-strategic-number sn-maximum-garrison-fill 15)
    (set-strategic-number sn-number-garrison-units 5)

    ; --- Idle Soldier Management ---
    (set-strategic-number sn-gather-idle-soldiers-at-center 1)
    (set-strategic-number sn-gather-defense-units 1)
    (set-strategic-number sn-task-ungrouped-soldiers 1)
    (set-strategic-number sn-number-civilian-militia 10)

    ; --- Difficulty: consistent behavior at all levels ---
    (set-strategic-number sn-do-not-scale-for-difficulty-level 1)
    (set-strategic-number sn-easiest-reaction-percentage 100)
    (set-strategic-number sn-easier-reaction-percentage 100)

    ; --- Cooperative Play (Team games) ---
    (set-strategic-number sn-coop-share-information 1)
    (set-strategic-number sn-coop-share-attacking 1)

    ; --- Advanced Building Targeting (defensive focus) ---
    (set-strategic-number sn-building-targeting-mode 1)
    (set-strategic-number sn-wall-targeting-mode 1)

    ; --- Force Stone Gates (fixes wooden gate bug) ---
    ; Value 0 = palisade gate (default), 1 = stone gate
    (set-strategic-number sn-gate-type-for-wall 1)

    (disable-self)
)

; ============================================================
; PHASE 1.5: HIGH RESOURCE START DETECTION (Aggressive Opening)
; When resources are abundant from the start, rush military + defenses simultaneously
; ============================================================

; --- Detect High Resource Start (e.g. High Resources game setting) ---
; If we have 500+ food and 500+ wood in Dark Age, go all-in aggression
(defrule
    (current-age == dark-age)
    (food-amount >= 500)
    (wood-amount >= 500)
    (building-type-count-total barracks < 2)
    (can-build barracks)
=>
    (build barracks)
    (chat-to-all "ZULFIKAR: High resources detected! Building war machine early!")
)

; --- HIGH RESOURCE / EXTREME MODE: Extra buildings when rich ---
(defrule
    (current-age >= feudal-age)
    (food-amount >= 400)
    (wood-amount >= 400)
    (building-type-count-total barracks < 3)
    (can-build barracks)
=>
    (build barracks)
)

(defrule
    (current-age >= feudal-age)
    (food-amount >= 300)
    (wood-amount >= 300)
    (building-type-count-total archery-range < 3)
    (can-build archery-range)
=>
    (build archery-range)
)

(defrule
    (current-age >= feudal-age)
    (food-amount >= 300)
    (wood-amount >= 200)
    (building-type-count-total stable < 1)
    (can-build stable)
=>
    (build stable)
)

; --- HIGH RESOURCE / EXTREME MODE: Scale army UP when resources overflow ---
; These only fire when resources are very high (500+), adding on top of Phase 12 caps.
; On normal games these rarely trigger. On High Resources/Ludikris they kick in hard.

; Dark Age: Extra militia when swimming in resources
(defrule
    (current-age <= feudal-age)
    (food-amount >= 500)
    (gold-amount >= 200)
    (unit-type-count-total militiaman-line < 8)
    (can-train militiaman-line)
=>
    (train militiaman-line)
)

; Feudal: Mass archers when rich
(defrule
    (current-age >= feudal-age)
    (food-amount >= 500)
    (wood-amount >= 500)
    (unit-type-count-total archer-line < 25)
    (can-train archer-line)
=>
    (train archer-line)
)

; Feudal: Extra skirmishers when rich
(defrule
    (current-age >= feudal-age)
    (food-amount >= 400)
    (gold-amount >= 200)
    (unit-type-count-total skirmisher-line < 12)
    (can-train skirmisher-line)
=>
    (train skirmisher-line)
)

; Castle: Mass knights when overflowing
(defrule
    (current-age >= castle-age)
    (food-amount >= 500)
    (gold-amount >= 500)
    (unit-type-count-total knight-line < 25)
    (can-train knight-line)
=>
    (train knight-line)
)

; Castle: Extra spearmen when rich
(defrule
    (current-age >= castle-age)
    (food-amount >= 500)
    (unit-type-count-total spearman-line < 25)
    (can-train spearman-line)
=>
    (train spearman-line)
)

; Imperial: Massive army when resources overflowing
(defrule
    (current-age >= imperial-age)
    (food-amount >= 500)
    (gold-amount >= 500)
    (unit-type-count-total knight-line < 40)
    (can-train knight-line)
=>
    (train knight-line)
)

(defrule
    (current-age >= imperial-age)
    (food-amount >= 500)
    (wood-amount >= 500)
    (unit-type-count-total archer-line < 40)
    (can-train archer-line)
=>
    (train archer-line)
)

(defrule
    (current-age >= imperial-age)
    (food-amount >= 500)
    (unit-type-count-total militiaman-line < 40)
    (can-train militiaman-line)
=>
    (train militiaman-line)
)

; Extra siege workshop + stable when swimming in resources
(defrule
    (current-age >= castle-age)
    (food-amount >= 500)
    (wood-amount >= 500)
    (building-type-count-total siege-workshop < 2)
    (can-build siege-workshop)
=>
    (build siege-workshop)
)

(defrule
    (current-age >= castle-age)
    (food-amount >= 500)
    (gold-amount >= 500)
    (building-type-count-total stable < 3)
    (can-build stable)
=>
    (build stable)
)

; Extra castles on extreme modes
(defrule
    (current-age >= castle-age)
    (stone-amount >= 1000)
    (building-type-count-total castle < 4)
    (can-build castle)
=>
    (build castle)
)

; ============================================================
; PHASE 1.6: STANDBY ARMY (Maintain Ready Garrison When Affordable)
; ============================================================
; These rules keep a large standing army when resources are healthy (200-300).
; They fill the gap between Phase 12 (small baseline) and extreme-mode (500+).
; The AI won't sit on unspent resources — it builds soldiers proactively.

; --- Feudal: Keep archers + spearmen ready ---
(defrule
    (current-age >= feudal-age)
    (food-amount >= 200)
    (wood-amount >= 200)
    (unit-type-count-total archer-line < 15)
    (can-train archer-line)
=>
    (train archer-line)
)

(defrule
    (current-age >= feudal-age)
    (food-amount >= 200)
    (unit-type-count-total spearman-line < 10)
    (can-train spearman-line)
=>
    (train spearman-line)
)

; --- Castle: Maintain a strong mixed garrison ---
(defrule
    (current-age >= castle-age)
    (food-amount >= 200)
    (gold-amount >= 200)
    (unit-type-count-total knight-line < 15)
    (can-train knight-line)
=>
    (train knight-line)
)

(defrule
    (current-age >= castle-age)
    (food-amount >= 200)
    (wood-amount >= 150)
    (unit-type-count-total archer-line < 25)
    (can-train archer-line)
=>
    (train archer-line)
)

(defrule
    (current-age >= castle-age)
    (food-amount >= 200)
    (unit-type-count-total spearman-line < 18)
    (can-train spearman-line)
=>
    (train spearman-line)
)

(defrule
    (current-age >= castle-age)
    (food-amount >= 200)
    (wood-amount >= 200)
    (unit-type-count-total skirmisher-line < 10)
    (can-train skirmisher-line)
=>
    (train skirmisher-line)
)

; --- Imperial: Keep a massive ready army ---
(defrule
    (current-age >= imperial-age)
    (food-amount >= 200)
    (gold-amount >= 200)
    (unit-type-count-total knight-line < 25)
    (can-train knight-line)
=>
    (train knight-line)
)

(defrule
    (current-age >= imperial-age)
    (food-amount >= 200)
    (wood-amount >= 100)
    (unit-type-count-total archer-line < 30)
    (can-train archer-line)
=>
    (train archer-line)
)

(defrule
    (current-age >= imperial-age)
    (food-amount >= 200)
    (unit-type-count-total militiaman-line < 25)
    (can-train militiaman-line)
=>
    (train militiaman-line)
)

(defrule
    (current-age >= imperial-age)
    (food-amount >= 200)
    (unit-type-count-total spearman-line < 25)
    (can-train spearman-line)
=>
    (train spearman-line)
)

; --- When entering Castle Age with high resources, immediately rush castle ---
(defrule
    (current-age >= castle-age)
    (stone-amount >= 650)
    (building-type-count-total castle < 1)
    (can-build castle)
=>
    (build castle)
    (chat-to-all "ZULFIKAR: Resources are abundant! Building a castle NOW!")
)

; --- If we have massive stone, build 2nd castle immediately ---
(defrule
    (current-age >= castle-age)
    (stone-amount >= 700)
    (building-type-count-total castle < 2)
    (can-build castle)
=>
    (build castle)
    (chat-to-all "ZULFIKAR: Fortress expanding! Second castle going up!")
)

; --- Under early attack: emergency military production ---
; CRITICAL: Train military IMMEDIATELY when attacked, regardless of resources
(defrule
    (town-under-attack)
    (unit-type-count-total militiaman-line < 10)
    (can-train militiaman-line)
=>
    (train militiaman-line)
)

(defrule
    (town-under-attack)
    (unit-type-count-total spearman-line < 8)
    (can-train spearman-line)
=>
    (train spearman-line)
)

(defrule
    (town-under-attack)
    (current-age >= feudal-age)
    (unit-type-count-total archer-line < 10)
    (can-train archer-line)
=>
    (train archer-line)
)

; --- Emergency buildings when attacked ---
(defrule
    (town-under-attack)
    (building-type-count-total barracks < 2)
    (can-build barracks)
=>
    (build barracks)
)

(defrule
    (town-under-attack)
    (current-age >= feudal-age)
    (building-type-count-total archery-range < 1)
    (can-build archery-range)
=>
    (build archery-range)
)

; --- Emergency tower when under early attack ---
(defrule
    (town-under-attack)
    (current-age >= feudal-age)
    (building-type-count-total watch-tower < 3)
    (can-build watch-tower)
=>
    (build watch-tower)
)

; --- HIGH RESOURCE + UNDER ATTACK = Full Emergency ---
